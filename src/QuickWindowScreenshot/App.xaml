<Application
    x:Class="QuickWindowScreenshot.App.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
            </ResourceDictionary.MergedDictionaries>

            <SolidColorBrush x:Key="AppChromeBrush" Color="#F4F7FB" />
            <SolidColorBrush x:Key="AppBodyBrush" Color="#F7F9FC" />
            <SolidColorBrush x:Key="PanelBorderBrush" Color="#D7DEE8" />
            <SolidColorBrush x:Key="MutedTextBrush" Color="#5D6675" />
            <Style x:Key="PanelSeparatorStyle" TargetType="Border">
                <Setter Property="Height" Value="1" />
                <Setter Property="Background" Value="{StaticResource PanelBorderBrush}" />
                <Setter Property="Opacity" Value="0.75" />
            </Style>
            <Style x:Key="SectionHeaderTextStyle" TargetType="TextBlock">
                <Setter Property="FontSize" Value="13" />
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="Foreground" Value="#263244" />
            </Style>
            <Style x:Key="FieldLabelTextStyle" TargetType="TextBlock">
                <Setter Property="FontSize" Value="12" />
                <Setter Property="VerticalAlignment" Value="Center" />
                <Setter Property="Foreground" Value="#3F4A5C" />
            </Style>
            <Style x:Key="PanelButtonStyle" TargetType="Button">
                <Setter Property="CornerRadius" Value="4" />
                <Setter Property="HorizontalAlignment" Value="Stretch" />
                <Setter Property="HorizontalContentAlignment" Value="Center" />
                <Setter Property="MinHeight" Value="34" />
                <Setter Property="Padding" Value="10,0" />
            </Style>
            <Style
                x:Key="PrimaryPanelButtonStyle"
                BasedOn="{StaticResource AccentButtonStyle}"
                TargetType="Button">
                <Setter Property="CornerRadius" Value="4" />
                <Setter Property="HorizontalAlignment" Value="Stretch" />
                <Setter Property="HorizontalContentAlignment" Value="Center" />
                <Setter Property="MinHeight" Value="34" />
                <Setter Property="Padding" Value="10,0" />
            </Style>
            <Style x:Key="PanelRadioButtonStyle" TargetType="RadioButton">
                <Setter Property="HorizontalAlignment" Value="Stretch" />
                <Setter Property="MinHeight" Value="34" />
            </Style>
            <Style x:Key="StatusActionButtonStyle" TargetType="Button">
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="BorderThickness" Value="0" />
                <Setter Property="CornerRadius" Value="4" />
                <Setter Property="FontSize" Value="12" />
                <Setter Property="Foreground" Value="{StaticResource MutedTextBrush}" />
                <Setter Property="MinHeight" Value="26" />
                <Setter Property="Padding" Value="8,0" />
            </Style>
            <Style x:Key="StatusTextStyle" TargetType="TextBlock">
                <Setter Property="FontSize" Value="12" />
                <Setter Property="Foreground" Value="{StaticResource MutedTextBrush}" />
                <Setter Property="VerticalAlignment" Value="Center" />
            </Style>
        </ResourceDictionary>
    </Application.Resources>
</Application>
